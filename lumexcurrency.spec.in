Name:                   lumexcurrency
Version:                @VERSION@ 
Release:                @RELEASE@%{?dist}
Summary:                Lumexcurrency Daemon
License:                BSD-2-Clause
URL:                    https://lumex.org/
Requires(pre):          /usr/sbin/useradd, /usr/bin/getent
Requires(postun):       /usr/sbin/userdel
BuildRequires:          make, glibc-devel, glibc-headers
Source:                 lumex-%{version}.tar.gz

%description
This is lumexcurrency daemon.  Lumex is a digital currency that is
peer-to-peer, decentralized, and trustless. This package includes
the lumex daemon, and a service.

%prep
if [ ! -x "$(which cmake)" ]; then
	echo "cmake must exist, try:" >&2
	echo "      scl enable gcc-toolset-12 'rpmbuild ...'" >&2
	exit 1
fi
if cc --std=c++20 --version 2>&1 >/dev/null | grep '^' >/dev/null; then
	echo "Unsupported C++ compiler, try:" >&2
	echo "      scl enable gcc-toolset-12 'rpmbuild ...'" >&2
	exit 1
fi
%autosetup -n lumex-%{version}

%build
cmake -DCMAKE_VERBOSE_MAKEFILE=ON .
make nano_node %{?_smp_mflags}
make nano_rpc %{?_smp_mflags}

%install
if [ ! %{buildroot} = "/" ]; then %{__rm} -rf %{buildroot}; fi
mkdir -p %{buildroot}/usr/bin
mkdir -p %{buildroot}/etc/systemd/system/
cp lumex_node %{buildroot}/usr/bin/lumex_node
cp lumex_rpc %{buildroot}/usr/bin/lumex_rpc
cp etc/systemd/lumexcurrency.service %{buildroot}/etc/systemd/system/lumexcurrency.service

%clean
if [ ! %{buildroot} = "/" ]; then %{__rm} -rf %{buildroot}; fi

%files
%defattr(755,root,root)
%{_bindir}/lumex_node
%{_bindir}/lumex_rpc
%attr(644,root,root) /etc/systemd/system/lumexcurrency.service

%pre
PATH="/usr/bin:/usr/sbin:/bin:/sbin:${PATH}"; export PATH
mkdir -p /var/lumexcurrency/Lumex
getent group lumexcurrency >/dev/null || groupadd --system lumexcurrency || exit 1
getent passwd lumexcurrency >/dev/null || useradd --system --create-home --home-dir /var/lumexcurrency --shell /bin/bash --comment "Lumexcurrency Daemon user" --gid lumexcurrency lumexcurrency || exit 1
chown -R lumexcurrency:lumexcurrency /var/lumexcurrency
chmod 700 /var/lumexcurrency

%postun
PATH="/usr/bin:/usr/sbin:/bin:/sbin:${PATH}"; export PATH
userdel lumexcurrency >/dev/null 2>/dev/null || :
